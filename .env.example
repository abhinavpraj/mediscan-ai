# 🏥 MediScan AI Configuration Example
# Copy this file to .env in your root directory as needed
# No authentication required - the app is open access

# ==========================================
# 🖥️ BACKEND CONFIGURATION
# ==========================================
# All backend settings are prefixed with MEDISCAN_
MEDISCAN_APP_NAME="MediScan AI"

# Local Storage Paths (inside the workspace)
MEDISCAN_DATABASE_PATH="backend/database/mediscan.sqlite3"
MEDISCAN_UPLOAD_DIR="backend/database/uploads"

# Local SLM/LLM GGUF Model Path
MEDISCAN_MODEL_PATH="models/phi-3-mini.gguf"

# CORS Allowed Origins
# For production, specify your Vercel URL
# Multiple values can be separated by commas
MEDISCAN_CORS_ORIGINS="http://localhost:5173,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://127.0.0.1:5173,https://mediscan-ai-abhinav-p.vercel.app"


# ==========================================
# 🌐 FRONTEND CONFIGURATION
# ==========================================
# Vite reads environment variables prefixed with VITE_
# For local development: leave empty (Vite proxy will handle /api)
# For Vercel production: set to your Render backend URL
VITE_API_BASE="https://mediscan-ai-2faj.onrender.com/api"
