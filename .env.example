# 🏥 MediScan AI Configuration Example
# Copy this file to .env in your root, backend, and frontend directories as needed

# ==========================================
# 🖥️ BACKEND CONFIGURATION
# ==========================================
# All backend settings are prefixed with MEDISCAN_
MEDISCAN_APP_NAME="MediScan AI"

# Local Storage Paths (inside the workspace)
MEDISCAN_DATABASE_PATH="backend/database/mediscan.sqlite3"
MEDISCAN_UPLOAD_DIR="backend/database/uploads"

# Local SLM/LLM GGUF Model Path
MEDISCAN_MODEL_PATH="models/phi-3-mini.gguf"

# Security & JWT Configuration
MEDISCAN_JWT_SECRET="replace-with-a-secure-random-secret-for-production"
MEDISCAN_ACCESS_TOKEN_MINUTES=480

# Demo Administrative Credentials
MEDISCAN_ADMIN_USERNAME="admin"
MEDISCAN_ADMIN_PASSWORD="mediscan-local"

# CORS Allowed Origins
# For production, specify your Vercel URL (e.g. "https://mediscan.vercel.app")
# Multiple values can be separated by commas
MEDISCAN_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"


# ==========================================
# 🌐 FRONTEND CONFIGURATION
# ==========================================
# Vite reads environment variables prefixed with VITE_
# For production, point this to your Render backend API (e.g. "https://mediscan-api.onrender.com/api")
VITE_API_BASE="http://localhost:8000/api"
